# ── Database ──────────────────────────────────────────────────
DATABASE_PATH=./data/hrp.db

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
BACKUP_DIR=./data/backups

# ── Server ───────────────────────────────────────────────────
# Required in production — must match your domain
ORIGIN=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# ── Auth ─────────────────────────────────────────────────────
# Secret for session token signing (generate with: openssl rand -hex 32)
AUTH_SECRET=change-me-to-a-random-64-char-hex-string

# ── Optional: OAuth (leave empty to disable) ─────────────────
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ── Limits ───────────────────────────────────────────────────
# Max upload size (adapter-node env var)
BODY_SIZE_LIMIT=100M
MAX_UPLOAD_MB=50

# ── Locale ───────────────────────────────────────────────────
DEFAULT_LOCALE=en
